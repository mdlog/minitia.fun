# Initia network — "testnet" (default) or "mainnet"
VITE_INITIA_NETWORK=testnet

# Minitia.fun appchain (our L2 rollup) — public tunnel endpoints.
# Powers the live block-height ticker and on-chain launch-count stat.
# Leave blank to disable rollup reads (hero stats fall back to mock data).
VITE_APPCHAIN_RPC=https://evonft.xyz
VITE_APPCHAIN_REST=https://nectiq.xyz

# Testnet faucet — drips 10 MIN to a given `init1…` so the wallet can
# afford its first MsgExecuteJSON. Run `node scripts/faucet-server.mjs`
# locally (default http://localhost:8090) or tunnel it publicly. Leave
# blank to hide the Get-MIN button.
VITE_APPCHAIN_FAUCET=http://localhost:8090/faucet
