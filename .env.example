# Initia network — "testnet" (default) or "mainnet"
VITE_INITIA_NETWORK=testnet

# Minitia.fun appchain (our L2 rollup) — public tunnel endpoints.
# Powers the live block-height ticker and on-chain launch-count stat.
# Leave blank to disable rollup reads (hero stats fall back to mock data).
VITE_APPCHAIN_RPC=https://rpc.minitia.fun
VITE_APPCHAIN_REST=https://rest.minitia.fun

# Testnet faucet — drips 10 MIN to a given `init1…` so the wallet can
# afford its first MsgExecuteJSON. Run `node scripts/faucet-server.mjs`
# locally (default http://localhost:8090) or tunnel it publicly. Leave
# blank to hide the Get-MIN button.
VITE_APPCHAIN_FAUCET=http://localhost:8090/faucet

# Pinata IPFS — used by Launchpad to pin token logos.
# The JWT ships in the client bundle, so anyone who inspects the JS can
# read it and use your quota. OK for testnet / hackathon. Production:
# proxy uploads through a backend that returns presigned upload URLs
# (see POST /v3/files/sign in the Pinata API docs).
# Leave VITE_PINATA_JWT blank to disable logo uploads (tokens launch
# without a logo; UI falls back to monogram avatars).
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud
