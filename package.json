    "@initia/initia.proto": "^1.0.6",
    "@initia/interwovenkit-react": "^2.6.0",
    "@tanstack/react-query": "^5.99.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.468.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4",
    "viem": "^2.48.1",
    "wagmi": "^2.17.2"
